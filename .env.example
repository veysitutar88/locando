# Neon Postgres connection string (Chunk #2)
# Format: postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Tenant slug used when accessing via localhost (no subdomain)
DEV_TENANT_SLUG=

# Public base URL of the app (used for OAuth redirect URIs, email links)
# Local: http://localhost:3000  |  Prod: https://locando.net
NEXT_PUBLIC_APP_URL=

# JWT signing secret (Chunk #9 — Passport.js + Google OAuth + JWT)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Google OAuth credentials (Chunk #9)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend API key for transactional email (Chunk #19)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
